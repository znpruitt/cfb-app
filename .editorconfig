# EditorConfig helps maintain consistent coding styles between editors & IDEs
# See https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{ts,tsx,js,jsx,json,yml,yaml,css,scss,html}]
indent_style = space
indent_size = 2

[*.{cjs,mjs}]
indent_style = space
indent_size = 2

[*.{sh,env}]
end_of_line = lf
indent_style = space
indent_size = 2

[*.bat]
end_of_line = crlf
indent_style = tab
