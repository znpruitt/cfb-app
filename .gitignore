# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*

# Yarn Berry
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js build output
/.next/
/out/

# production build
/build

# misc system files
.DS_Store
*.pem

# debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# environment files (never commit secrets)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# vercel
.vercel

# typescript artifacts
*.tsbuildinfo
next-env.d.ts

# IDE/editor settings
.vscode/
.idea/
*.swp

# lint/test caches
.eslintcache
jest-test-results.json

# -----------------------------
# Project-specific data
# -----------------------------

# Keep aliases under version control
# (do NOT ignore data/aliases-*.json)

# Ignore transient data files if any
# (but keep your canonical teams catalog)
data/*.json
!data/teams-*.json
!data/aliases-*.json
